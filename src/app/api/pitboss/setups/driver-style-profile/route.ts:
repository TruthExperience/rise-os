// File: src/app/api/pitboss/setups/driver-style-profile/route.ts
//
// Session-gated GET/PUT for the calling driver's own row in
// pitboss.driver_style_profiles. Unlike career_mode_drivers (a searchable
// library, no ownership), this table has a real 1:1 tie to a driver via the
// unique driver_id column, so it's resolved from the session the same way
// the rest of the app treats "my own record" — session.user.discordId ->
// pitboss.drivers.id — not a route param.

import { NextResponse } from "next/server";
import { getServerSession } from "next-auth";
import { authOptions } from "@/lib/auth";
import { createAdminClient } from "@/lib/supabase/server";

const CAR_FEEL_OPTIONS = [
  "loose_oversteer",
  "planted_understeer",
  "balanced",
  "aggressive_rotation",
  "stable_predictable",
] as const;

const RACE_LENGTH_OPTIONS = [
  "5_lap",
  "25_percent",
  "35_percent",
  "50_percent",
  "100_percent",
] as const;

async function resolveDriverId(discordId: string) {
  const supabase = createAdminClient();
  const { data, error } = await supabase
    .schema("pitboss")
    .from("drivers")
    .select("id")
    .eq("discord_id", discordId)
    .maybeSingle();

  if (error) throw new Error(`Failed to resolve driver: ${error.message}`);
  return data?.id ?? null;
}

export async function GET() {
  const session = await getServerSession(authOptions);
  const discordId = session?.user?.discordId;
  if (!discordId) {
    return NextResponse.json({ error: "Not authenticated" }, { status: 401 });
  }

  const driverId = await resolveDriverId(discordId);
  if (!driverId) {
    return NextResponse.json({ error: "Driver record not found" }, { status: 404 });
  }

  const supabase = createAdminClient();
  const { data, error } = await supabase
    .schema("pitboss")
    .from("driver_style_profiles")
    .select(
      "id, driver_id, comparison_drivers, car_feel_preference, car_feel_notes, preferred_race_length, assists, notes, created_at, updated_at"
    )
    .eq("driver_id", driverId)
    .maybeSingle();

  if (error) {
    return NextResponse.json({ error: error.message }, { status: 500 });
  }

  return NextResponse.json({ profile: data ?? null });
}

interface PutBody {
  car_feel_preference: string;
  preferred_race_length: string;
  assists?: Record<string, unknown>;
  comparison_drivers?: string | null;
  car_feel_notes?: string | null;
  notes?: string | null;
}

export async function PUT(req: Request) {
  const session = await getServerSession(authOptions);
  const discordId = session?.user?.discordId;
  if (!discordId) {
    return NextResponse.json({ error: "Not authenticated" }, { status: 401 });
  }

  const driverId = await resolveDriverId(discordId);
  if (!driverId) {
    return NextResponse.json({ error: "Driver record not found" }, { status: 404 });
  }

  let body: PutBody;
  try {
    body = await req.json();
  } catch {
    return NextResponse.json({ error: "Invalid JSON body" }, { status: 400 });
  }

  const { car_feel_preference, preferred_race_length, assists, comparison_drivers, car_feel_notes, notes } = body;

  if (!CAR_FEEL_OPTIONS.includes(car_feel_preference as (typeof CAR_FEEL_OPTIONS)[number])) {
    return NextResponse.json({ error: "Invalid car_feel_preference" }, { status: 400 });
  }
  if (!RACE_LENGTH_OPTIONS.includes(preferred_race_length as (typeof RACE_LENGTH_OPTIONS)[number])) {
    return NextResponse.json({ error: "Invalid preferred_race_length" }, { status: 400 });
  }

  const supabase = createAdminClient();
  const { data, error } = await supabase
    .schema("pitboss")
    .from("driver_style_profiles")
    .upsert(
      {
        driver_id: driverId,
        car_feel_preference,
        preferred_race_length,
        assists: assists ?? {},
        comparison_drivers: comparison_drivers ?? null,
        car_feel_notes: car_feel_notes ?? null,
        notes: notes ?? null,
        updated_at: new Date().toISOString(),
      },
      { onConflict: "driver_id" }
    )
    .select(
      "id, driver_id, comparison_drivers, car_feel_preference, car_feel_notes, preferred_race_length, assists, notes, created_at, updated_at"
    )
    .single();

  if (error || !data) {
    return NextResponse.json({ error: error?.message ?? "Failed to save style profile" }, { status: 500 });
  }

  return NextResponse.json({ profile: data });
}
